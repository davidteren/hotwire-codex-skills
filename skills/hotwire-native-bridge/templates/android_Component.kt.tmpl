package __PACKAGE__

import android.util.Log
import dev.hotwire.core.bridge.BridgeComponent
import dev.hotwire.core.bridge.BridgeDelegate
import dev.hotwire.core.bridge.Message
import dev.hotwire.navigation.destinations.HotwireDestination
import kotlinx.serialization.SerialName
import kotlinx.serialization.Serializable

// Android half of the "__COMPONENT_NAME__" bridge component (Hotwire Native 1.x).
// File: .../__CLASS_NAME__Component.kt
// `name` is the CONTRACT — must match web (static component) + iOS byte-for-byte.
//
// Hotwire Native 1.x note: bridge classes are now in dev.hotwire.core.bridge
// (formerly dev.hotwire.strada), the destination type is HotwireDestination
// (formerly NavDestination), and registration moves to an Application subclass:
//
//   Hotwire.registerBridgeComponents(
//     BridgeComponentFactory("__COMPONENT_NAME__", ::__CLASS_NAME__Component)
//   )
//   // also: Hotwire.config.jsonConverter = KotlinXJsonConverter()
class __CLASS_NAME__Component(
  name: String,
  private val delegate: BridgeDelegate<HotwireDestination>
) : BridgeComponent<HotwireDestination>(name, delegate) {

  override fun onReceive(message: Message) {
    when (message.event) {
      "connect" -> handleConnect(message)
      "disconnect" -> handleDisconnect()
      else -> Log.w("Bridge", "Unknown event for $name: $message")
    }
  }

  private fun handleConnect(message: Message) {
    val data = message.data<MessageData>() ?: return
    // TODO: render native UI from data.items, replying via replyTo("connect", ...)
    // when the user picks one.
    data.items.forEach { /* addMenuItem(it) */ }
  }

  private fun handleDisconnect() {
    // TODO: remove whatever handleConnect rendered (e.g. toolbar menu items).
  }

  @Serializable
  data class MessageData(
    @SerialName("items") val items: List<Item>
  )

  // Mirror of the web payload. EVERY key the web sends must appear here or it is
  // silently dropped (the classic web/Android divergence — e.g. an `icon` field
  // present on web + iOS but missing here). Keep in sync with the JS controller.
  @Serializable
  data class Item(
    @SerialName("title") val title: String,
    @SerialName("index") val index: Int,
    @SerialName("icon") val icon: String? = null
  )

  @Serializable
  data class ResponseData(
    @SerialName("selectedIndex") val selectedIndex: Int
  )
}
