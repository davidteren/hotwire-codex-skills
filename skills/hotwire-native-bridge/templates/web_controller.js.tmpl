import { BridgeComponent, BridgeElement } from "@hotwired/strada"

// Web half of the "__COMPONENT_NAME__" Strada bridge component.
// File: app/javascript/controllers/bridge/__SNAKE_NAME___controller.js
// Stimulus identifier: bridge--__COMPONENT_NAME__
// The `component` string below is the CONTRACT — it must match the iOS
// (override class var name) and Android (BridgeComponentFactory) sides byte-for-byte.
export default class extends BridgeComponent {
  static component = "__COMPONENT_NAME__"
  static targets = [ "item" ]

  connect() {
    // When running inside a native app, hide the web fallback UI and hand the
    // data to the native side. On plain web (no bridge), connect() never runs.
    this.element.classList.add("is-hidden")

    const items =
      this.itemTargets
        .map(item => new BridgeElement(item))
        .map((item, index) => ({
          title: item.title,
          // Keep this payload shape identical across web/iOS/Android. Any key you
          // add here must be decoded on BOTH native sides or it is silently dropped.
          icon: item.bridgeAttribute("icon"),
          index
        }))

    this.send("connect", { items }, message => {
      const selectedIndex = message.data.selectedIndex
      const selectedItem = new BridgeElement(this.itemTargets[selectedIndex])
      selectedItem.click()
    })
  }

  disconnect() {
    // Tell native to tear down anything it rendered, so it doesn't duplicate on
    // the next Turbo navigation. Pairs with the native disconnect handler.
    this.send("disconnect")
  }
}
